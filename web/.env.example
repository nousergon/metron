# Backend base URL (the FastAPI service in ../api).
METRON_API_URL=http://localhost:8000

# Shared identity service (nousergon-auth, metron-ops#179). Owns sign-in, sessions,
# and the invite gate for ALL Nous Ergon products; Metron runs no auth of its own
# (no auth DB, no auth secret, no email sender here). NEXT_PUBLIC_ because the
# browser-side auth client talks to it directly (magic-link request, get-session).
NEXT_PUBLIC_AUTH_URL=https://auth.nousergon.ai
