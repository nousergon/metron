# Backend base URL (the FastAPI service in ../api).
METRON_API_URL=http://localhost:8000

# Auth (Better Auth). Generate a secret: `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Auth database. Dev: a local SQLite file. Prod: a Postgres URL (swap the dialect in
# lib/auth.ts when that lands).
AUTH_DATABASE_URL=./auth.sqlite
