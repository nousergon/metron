# Backend base URL (the FastAPI service in ../api).
METRON_API_URL=http://localhost:8000

# Auth (Better Auth). Generate a secret: `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Auth database. Dev: a local SQLite file. Prod: a Postgres URL (swap the dialect in
# lib/auth.ts when that lands).
AUTH_DATABASE_URL=./auth.sqlite

# Email transport for magic-link sign-in (Resend). EMAIL_SENDER must be an address on a
# Resend-verified domain (e.g. no-reply@nousergon.ai) so SPF/DKIM/DMARC align and the
# link isn't spam-filtered. RESEND_API_KEY is the provider key. Without these, requesting
# a sign-in link fails loud with a reason.
EMAIL_SENDER=no-reply@nousergon.ai
RESEND_API_KEY=

# Invite gate (private beta, metron-ops#18): a brand-new email must submit a valid,
# unused invite code (the `inviteCode` table — see lib/invite-gate.ts for how to seed
# rows) to sign up. Returning users are never gated. Default ON — set to "false" only
# for local/dev convenience, or once the beta opens to public signup.
# INVITE_GATE_ENABLED=false
