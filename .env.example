# Copy to .env for local dev. Defaults are chosen so the app runs with NO paid
# vendor anywhere in the loop.

# Database. Dev default is a local SQLite file (zero cost). For production point at
# Postgres: postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./dev.sqlite

# CORS origins for the (future) Next.js frontend, comma-separated.
CORS_ORIGINS=http://localhost:3000

# App metadata
ENV=dev

# --- SnapTrade (personal/single-operator brokerage sync, e.g. Fidelity) ---
# OFF by default. Set true ONLY on a single-tenant (personal) deploy: it enables a
# server-side SnapTrade sync that uses ONE operator connection shared by the process.
# Never enable on a multi-tenant deploy — M2 uses a per-user connection portal instead.
SNAPTRADE_PERSONAL=false
# The operator's SnapTrade credentials + linked-user secret (from SnapTrade's dashboard
# + a one-time user registration). Required when SNAPTRADE_PERSONAL=true.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=
# Optional institution allowlist (comma-separated). When set, the SnapTrade sync imports
# ONLY accounts at these institutions — e.g. "Fidelity" so IBKR can be sourced from Flex
# (better data) without double-counting. Empty → import all linked accounts.
SNAPTRADE_INSTITUTIONS=
