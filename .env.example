# Copy to .env for local dev. Defaults are chosen so the app runs with NO paid
# vendor anywhere in the loop.

# Database. Dev default is a local SQLite file (zero cost). For production point at
# Postgres: postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./dev.sqlite

# CORS origins for the (future) Next.js frontend, comma-separated.
CORS_ORIGINS=http://localhost:3000

# App metadata
ENV=dev
