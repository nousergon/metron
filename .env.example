# Copy to .env for local dev. Defaults are chosen so the app runs with NO paid
# vendor anywhere in the loop.

# Database. Dev default is a local SQLite file (zero cost). For production point at
# Postgres: postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./dev.sqlite

# CORS origins for the (future) Next.js frontend, comma-separated.
CORS_ORIGINS=http://localhost:3000

# App metadata
ENV=dev

# --- SnapTrade (personal/single-operator brokerage sync, e.g. Fidelity) ---
# OFF by default. Set true ONLY on a single-tenant (personal) deploy: it enables a
# server-side SnapTrade sync that uses ONE operator connection shared by the process.
# Never enable on a multi-tenant deploy — M2 uses a per-user connection portal instead.
SNAPTRADE_PERSONAL=false
# The operator's SnapTrade credentials + linked-user secret (from SnapTrade's dashboard
# + a one-time user registration). Required when SNAPTRADE_PERSONAL=true.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=
# Every linked connection syncs by default. To keep a broker sourced elsewhere (e.g.
# IBKR via Flex) from double-counting, exclude its connection in-product (SnapTrade
# card -> Exclude) — exclusion is per-connection by stable id, no name matching.
# (The former SNAPTRADE_INSTITUTIONS allowlist is removed; a leftover env var is ignored.)

# --- IBKR Flex (stored credentials for one-click sync; metron-ops#82) ---
# When BOTH are set, the IBKR sync runs from these (a "Sync IBKR" button, no token paste)
# and /meta reports connectors.flex_stored=true. Single-operator owner build only — the
# Flex token is a secret (read-only, expirable). Leave empty to keep the BYO-token form.
FLEX_TOKEN=
FLEX_QUERY_ID=

# --- Data axes: S3 spine (infra) vs feed entitlement (product) — kept SEPARATE ---
# These are two INDEPENDENT toggles (decoupled per metron-ops#43 — conflating them
# silently emptied the owner build's Risk page). Both default sensibly for the
# personal/owner build; the public multi-tenant BETA deploy overrides them.
#
# MARKET_DATA_SYNC_ENABLED — INFRA only: does this process talk to the alpha-engine S3
# data-spine (publish held-ticker universe, read EOD-close/FX artifacts, write UI
# heartbeat)? OFF by default so dev/tests never reach S3; the box deploy (instance role
# grants the bucket) sets it true. It does NOT gate any analytics.
# MARKET_DATA_SYNC_ENABLED=false
#
# FEED_ENTITLED — PRODUCT only: does this deployment OFFER the feed-dependent wedge
# (Risk / Attribution / Scenarios / Benchmark)? Risk/Attribution compute factor history
# via on-demand price backfill, INDEPENDENT of the S3 spine — so the owner build is fully
# provisioned even with the spine off. Default true (personal/owner build). The public
# BETA deploy sets FEED_ENTITLED=false (+ DEFAULT_TIER=beta) so the no-feed beta shows
# only the free-derivable set.
# FEED_ENTITLED=true
#
# DEFAULT_TIER — product packaging tier this deployment serves: personal | agentic | pro
# | beta. Default "personal" (owner build = full superset). The public beta sets "beta".
# DEFAULT_TIER=personal
